# Google OAuth credentials (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Google Picker API key (create at console.cloud.google.com/apis/credentials
# → + Create Credentials → API key. Restrict to Google Picker API only.
# Safe to expose to client JS — it's a public key by design.)
GOOGLE_API_KEY=your-picker-api-key

# Public URL of the deployed server
BASE_URL=https://your-app.up.railway.app

# Port (Railway sets this automatically via PORT env var)
PORT=3777
